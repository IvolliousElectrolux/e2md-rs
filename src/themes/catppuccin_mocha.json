          "emphasis.strong": { "font_weight": 700 },
          "function": { "color": "#89b4fa" },
          "keyword": { "color": "#cba6f7" },
          "link_text": { "color": "#89b4fa", "font_style": "normal" },
          "link_uri": { "color": "#6c7086", "font_style": "italic" },
          "number": { "color": "#fab387" },
          "string": { "color": "#a6e3a1" },
          "string.escape": { "color": "#cba6f7" },
          "string.regex": { "color": "#a6e3a1" },
          "string.special": { "color": "#f38ba8" },
          "string.special.symbol": { "color": "#f38ba8" },
          "tag": { "color": "#f38ba8" },
          "text.literal": { "color": "#a6e3a1" },
          "text.code.span": { "color": "#a6e3a1" },
          "title": { "color": "#cba6f7", "font_weight": 600 },
          "type": { "color": "#89dceb" },
          "property": { "color": "#89dceb" },
          "variable": { "color": "#cdd6f4" },
          "variable.special": { "color": "#f38ba8" }
