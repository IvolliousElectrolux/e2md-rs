        "tab.foreground": "#93a1a1",
        "table.background": "#fdf6e3",
        "table.head.foreground": "#93a1a1",
        "table.row.border": "#e8dfc8b3",
        "tiles.background": "#eee8d5",
        "title_bar.background": "#eee8d5",
        "title_bar.border": "#d8d1be",
        "status_bar.background": "#eee8d5",
        "status_bar.border": "#d8d1be",
        "warning.background": "#b58900",
        "warning.foreground": "#fdf6e3",
        "overlay": "#0000000d",
        "window.border": "#e8dfc8",
        "base.red": "#dc322f",
        "base.red.light": "#e34c49",
        "base.green": "#859900",
        "base.green.light": "#98aa00",
        "base.blue": "#268bd2",
        "base.blue.light": "#4099d6",
        "base.yellow": "#b58900",
        "base.yellow.light": "#c89a00",
        "base.magenta": "#d33682",
        "base.magenta.light": "#d9508e",
        "base.cyan": "#2aa198",
        "base.cyan.light": "#37b3aa"
