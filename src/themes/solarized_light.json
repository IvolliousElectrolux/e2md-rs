        "secondary.foreground": "#657b83",
        "secondary.hover.background": "#e2dccc",
        "selection.background": "#a8d4f5",
        "sidebar.background": "#eee8d5",
        "sidebar.accent.background": "#d8d1be",
        "sidebar.accent.foreground": "#586e75",
        "sidebar.border": "#d8d1be",
        "sidebar.foreground": "#586e75",
        "sidebar.primary.background": "#268bd2",
