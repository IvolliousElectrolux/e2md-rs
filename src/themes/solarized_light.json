      "highlight": {
        "editor.foreground": "#657b83",
        "editor.background": "#fdf6e3",
        "editor.active_line.background": "#eee8d5",
        "editor.line_number": "#93a1a1",
        "editor.active_line_number": "#657b83",
        "editor.invisible": "#93a1a166",
        "conflict": "#dc322f",
        "created": "#859900",
        "hidden": "#93a1a1",
        "hint": "#6c71c4",
        "modified": "#b58900",
        "predictive": "#93a1a1",
        "warning": "#b58900",
