          "attribute": { "color": "#859900" },
          "boolean": { "color": "#cb4b16" },
          "comment": { "color": "#93a1a1", "font_style": "italic" },
          "comment.doc": { "color": "#93a1a1", "font_style": "italic" },
          "constant": { "color": "#cb4b16" },
          "constructor": { "color": "#268bd2" },
          "embedded": { "color": "#657b83" },
          "emphasis": { "font_style": "italic" },
          "emphasis.strong": { "font_weight": 700 },
          "function": { "color": "#268bd2" },
          "keyword": { "color": "#859900" },
          "link_text": { "color": "#268bd2", "font_style": "normal" },
          "link_uri": { "color": "#93a1a1", "font_style": "italic" },
          "number": { "color": "#2aa198" },
          "string": { "color": "#2aa198" },
          "string.escape": { "color": "#dc322f" },
          "string.regex": { "color": "#2aa198" },
          "string.special": { "color": "#d33682" },
          "string.special.symbol": { "color": "#d33682" },
          "tag": { "color": "#859900" },
          "text.literal": { "color": "#2aa198" },
          "text.code.span": { "color": "#2aa198" },
          "title": { "color": "#268bd2", "font_weight": 600 },
          "type": { "color": "#b58900" },
          "property": { "color": "#657b83" },
          "variable": { "color": "#657b83" },
          "variable.special": { "color": "#dc322f" }
        }
