{
  "$schema": "https://github.com/longbridge/gpui-component/raw/refs/heads/main/.theme-schema.json",
  "name": "Solarized Light",
  "author": "Ethan Schoonover",
  "url": "https://ethanschoonover.com/solarized",
  "themes": [
    {
      "name": "Solarized Light",
      "mode": "light",
      "colors": {
        "accent.background": "#eee8d5",
        "accent.foreground": "#657b83",
        "background": "#fdf6e3",
        "border": "#e8dfc8",
        "caret": "#657b83",
        "danger.background": "#dc322f",
        "danger.foreground": "#fdf6e3",
        "drag_border": "#268bd2",
        "drop_target.background": "#268bd219",
        "foreground": "#657b83",
        "info.background": "#2aa198",
        "info.foreground": "#fdf6e3",
        "input.border": "#e8dfc8",
        "link.foreground": "#268bd2",
        "link.active.foreground": "#2aa198",
        "link.hover.foreground": "#6c71c4",
        "list.background": "#fdf6e3",
        "list.active.background": "#eee8d533",
        "list.active.border": "#268bd2",
        "list.even.background": "#fdf6e366",
        "list.head.background": "#eee8d5",
        "list.hover.background": "#eee8d5",
        "muted.background": "#eee8d5",
        "muted.foreground": "#93a1a1",
        "popover.background": "#fdf6e3",
        "popover.foreground": "#657b83",
        "primary.background": "#268bd2",
        "primary.active.background": "#2196be",
        "primary.foreground": "#fdf6e3",
        "primary.hover.background": "#3094d4",
        "progress_bar.background": "#268bd2",
        "ring": "#268bd2",
        "scrollbar.background": "#fdf6e300",
